# Database (point to shared TRPL DB for now)
DB_DATABASE=../TRPL-Web/backend/database/trpl_web.sqlite

# Server
PORT=9090
GIN_MODE=debug

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Google OAuth2
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URL=http://localhost:9090/api/auth/google/callback
ALLOWED_DOMAIN=pnc.ac.id

# App URLs
FRONTEND_URL=http://localhost:5173
TRPL_BACKEND_URL=http://localhost:8080
